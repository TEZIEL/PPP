{
  "scriptId": "drink_system_stress_test",
  "nodes": [
    {
      "id": "lb.start",
      "type": "Label",
      "label": "start"
    },
    {
      "id": "t.1",
      "type": "Say",
      "text": "테스트를 시작할게.",
      "speakerId": "세나"
    },
    {
      "id": "t.2",
      "type": "Say",
      "text": "이 스크립트는 시스템 안정성 테스트야. 분기 값은 lastDrink 기준으로 1=great, 2=success, else=fail이야.",
      "speakerId": "세나"
    },
    {
      "id": "t.3",
      "type": "Say",
      "text": "스킵이나 오토를 켜도 좋아.",
      "speakerId": "세나"
    },
    {
      "id": "t.4",
      "type": "Say",
      "text": "세이브도 중간에 해보고.",
      "speakerId": "세나"
    },
    {
      "id": "t.5",
      "type": "Say",
      "text": "포커스 이동도 테스트해봐.",
      "speakerId": "세나"
    },
    {
      "id": "t.10",
      "type": "Say",
      "text": "첫 번째 음료 부탁해.",
      "speakerId": "멜리온"
    },
    {
      "id": "call.1",
      "type": "Call",
      "target": "Drink",
      "arg": "REQ_TEST_LATTE"
    },
    {
      "id": "branch.1",
      "type": "Branch",
      "branches": [
        {
          "expr": "lastDrink==1",
          "jumpLabel": "great1"
        },
        {
          "expr": "lastDrink==2",
          "jumpLabel": "success1"
        },
        {
          "expr": "else",
          "jumpLabel": "fail1"
        }
      ]
    },
    {
      "id": "great1",
      "type": "Label",
      "label": "great1"
    },
    {
      "id": "g1",
      "type": "Say",
      "text": "완벽해.",
      "speakerId": "세나"
    },
    {
      "id": "jump1",
      "type": "Jump",
      "label": "phase2"
    },
    {
      "id": "success1",
      "type": "Label",
      "label": "success1"
    },
    {
      "id": "s1",
      "type": "Say",
      "text": "괜찮네.",
      "speakerId": "세나"
    },
    {
      "id": "jump2",
      "type": "Jump",
      "label": "phase2"
    },
    {
      "id": "fail1",
      "type": "Label",
      "label": "fail1"
    },
    {
      "id": "f1",
      "type": "Say",
      "text": "이건 아니야.",
      "speakerId": "세나"
    },
    {
      "id": "jump3",
      "type": "Jump",
      "label": "phase2"
    },
    {
      "id": "phase2",
      "type": "Label",
      "label": "phase2"
    },
    {
      "id": "t20",
      "type": "Say",
      "text": "좋아, 두 번째 테스트야.",
      "speakerId": "세나"
    },
    {
      "id": "t21",
      "type": "Say",
      "text": "지금 스킵을 켜도 좋아.",
      "speakerId": "세나"
    },
    {
      "id": "t22",
      "type": "Say",
      "text": "Auto도 켜보고.",
      "speakerId": "세나"
    },
    {
      "id": "t23",
      "type": "Say",
      "text": "세이브도 해봐.",
      "speakerId": "세나"
    },
    {
      "id": "t24",
      "type": "Say",
      "text": "그리고 음료를 하나 더 만들어줘.",
      "speakerId": "세나"
    },
    {
      "id": "call.2",
      "type": "Call",
