{
  "scriptId": "drink_test",
  "nodes": [

    { "id": "lb.start", "type": "Label", "label": "start" },

    {
      "id": "t.001",
      "type": "Say",
      "speaker": "세나",
      "text": "안녕, 이건 테스트 스크립트야."
    },

    {
      "id": "t.002",
      "type": "Say",
      "speaker": "세나",
      "text": "짧은 테스트지만 잘 부탁해."
    },

    {
      "id": "t.003",
      "type": "Say",
      "speaker": "멜리온",
      "text": "뭔가 마시고 싶다며?"
    },

    {
      "id": "t.004",
      "type": "Say",
      "speaker": "세나",
      "text": "카페라떼 하나만 부탁해."
    },

    {
      "id": "call.1",
      "type": "Call",
      "target": "Drink",
      "arg": "REQ_TEST_LATTE"
    },

    {
      "id": "branch.1",
      "type": "Branch",
      "branches": [
        { "cond": "lastDrink==1", "next": "latte_great" },
        { "cond": "lastDrink==2", "next": "latte_success" },
        { "cond": "else", "next": "latte_fail" }
      ]
    },

    { "id": "lb.latte_great", "type": "Label", "label": "latte_great" },

    {
      "id": "t.g1",
      "type": "Say",
      "speaker": "세나",
      "text": "정확해."
    },

    { "id": "jump1", "type": "Jump", "next": "drink2" },



