{
  "scriptId": "drink_test_branch_basic",
  "nodes": [
    { "id": "start", "type": "Label", "label": "start" },

    { "id": "t1", "type": "Say", "text": "분기 테스트 시작", "speakerId": "세나" },

    {
      "id": "call.1",
      "type": "Call",
      "target": "Drink",
      "arg": "REQ_TEST_COLA"
    },

    {
      "id": "branch.1",
      "type": "Branch",
      "branches": [
        { "expr": "lastDrink==1", "jumpLabel": "great" },
        { "expr": "lastDrink==2", "jumpLabel": "success" },
        { "expr": "else", "jumpLabel": "fail" }
      ]
    },

    { "id": "great", "type": "Label", "label": "great" },
    { "id": "g1", "type": "Say", "text": "완벽한 한 잔이야.", "speakerId": "세나" },
    { "id": "jg", "type": "Jump", "label": "end" },

    { "id": "success", "type": "Label", "label": "success" },
    { "id": "s1", "type": "Say", "text": "괜찮은 맛이네.", "speakerId": "세나" },
    { "id": "js", "type": "Jump", "label": "end" },

    { "id": "fail", "type": "Label", "label": "fail" },
    { "id": "f1", "type": "Say", "text": "이건 좀 아니다.", "speakerId": "세나" },
    { "id": "jf", "type": "Jump", "label": "end" },

    { "id": "end", "type": "Label", "label": "end" },
    { "id": "tend", "type": "Say", "text": "분기 테스트 종료", "speakerId": "sys" },
    { "id": "endnode", "type": "End" }
  ]
}