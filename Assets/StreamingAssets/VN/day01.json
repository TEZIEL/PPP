    {
      "id": "phase3",
      "type": "Label",
      "label": "phase3"
    },
    {
      "id": "t30",
      "type": "Say",
      "text": "세 번째 테스트.",
      "speakerId": "세나"
    },
    {
      "id": "t31",
      "type": "Say",
      "text": "이 구간은 스킵 안정성 확인용이야.",
      "speakerId": "세나"
    },
    {
      "id": "t32",
      "type": "Say",
      "text": "대사를 많이 넣어둘게.",
      "speakerId": "세나"
    },
    {
      "id": "t33",
      "type": "Say",
      "text": "지금 Skip을 켜고 진행해봐.",
      "speakerId": "세나"
