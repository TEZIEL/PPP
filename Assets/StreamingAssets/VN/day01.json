    {
      "id": "t.s1",
      "type": "Say",
      "speaker": "세나",
      "text": "잘 마실게."
    },

    { "id": "jump2", "type": "Jump", "next": "drink2" },



    { "id": "lb.latte_fail", "type": "Label", "label": "latte_fail" },

    {
      "id": "t.f1",
      "type": "Say",
      "speaker": "세나",
      "text": "이게 아닌데."
    },

    { "id": "jump3", "type": "Jump", "next": "drink2" },



