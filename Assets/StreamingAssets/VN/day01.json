      "id": "t.af",
      "type": "Say",
      "speaker": "세나",
      "text": "음... 이건 아닌 것 같아."
    },

    { "id": "jump9", "type": "Jump", "next": "end" },



    { "id": "lb.end", "type": "Label", "label": "end" },

    {
      "id": "t.end",
      "type": "Say",
