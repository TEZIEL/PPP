    {
      "id": "t.cs",
      "type": "Say",
      "speaker": "세나",
      "text": "잘 마실게."
    },

    { "id": "jump5", "type": "Jump", "next": "drink3" },



    { "id": "lb.cola_fail", "type": "Label", "label": "cola_fail" },

    {
      "id": "t.cf",
      "type": "Say",
      "speaker": "세나",
      "text": "이건 콜라가 아닌데."
    },

    { "id": "jump6", "type": "Jump", "next": "drink3" },



